{
  "name": "@twodogwang/unocss-preset-tailwind3",
  "version": "1.0.0-beta.1",
  "type": "module",
  "description": "Pure Tailwind CSS 3.x preset for UnoCSS",
  "author": "twodogwang <a381097999@qq.com>",
  "license": "MIT",
  "sideEffects": false,
  "packageManager": "pnpm@10.33.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/twodogwang/unocss-preset-tailwind3.git"
  },
  "homepage": "https://github.com/twodogwang/unocss-preset-tailwind3#readme",
  "bugs": {
    "url": "https://github.com/twodogwang/unocss-preset-tailwind3/issues"
  },
  "keywords": [
    "unocss",
    "unocss-preset",
    "tailwindcss",
    "tailwind3"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./eslint": {
      "types": "./dist/eslint.d.mts",
      "import": "./dist/eslint.mjs"
    },
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "ci": "pnpm run typecheck && pnpm build && pnpm test && pnpm run test:fixtures",
    "changeset": "changeset",
    "dev": "tsdown --watch",
    "lint:fixture:ide": "pnpm --filter ide-eslint-fixture lint",
    "prepublishOnly": "pnpm run ci",
    "release:publish": "changeset publish",
    "release:publish:beta": "changeset publish",
    "release:notes": "node scripts/release-notes.mjs",
    "rewrite:finish-family": "node scripts/rewrite-finish-family.mjs --",
    "rewrite:next-family": "node scripts/rewrite-next-family.mjs",
    "test": "vitest --run",
    "test:fixtures": "pnpm --filter ide-eslint-fixture lint && pnpm --filter ide-eslint-fixture verify:autofix",
    "test:watch": "vitest",
    "typecheck": "oxlint . --type-aware --type-check -A all",
    "typecheck:tsc": "tsc --noEmit",
    "version:prerelease:enter:beta": "changeset pre enter beta",
    "version:prerelease:exit": "changeset pre exit",
    "version:release": "changeset version"
  },
  "dependencies": {
    "@unocss/core": "^66.6.0",
    "@unocss/extractor-arbitrary-variants": "^66.6.0",
    "@unocss/rule-utils": "^66.6.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.7",
    "@types/node": "^24.5.2",
    "@unocss/autocomplete": "^66.6.0",
    "oxlint": "^1.60.0",
    "oxlint-tsgolint": "^0.20.0",
    "postcss": "^8.5.6",
    "tailwindcss": "3.4.17",
    "tsdown": "^0.21.7",
    "tsx": "^4.20.3",
    "typescript": "^5.9.2",
    "vitest": "^4.1.3"
  }
}
